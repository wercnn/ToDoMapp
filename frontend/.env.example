# ----------------------------------------------------------------------------
# TodoMapp web frontend — environment
# Copy to `.env.local` (gitignored) and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# ----------------------------------------------------------------------------

# Full base URL of the /v1 API, INCLUDING the /v1 path. No default — the app
# throws at startup if this is unset, so a misconfig fails loud instead of
# silently hitting the frontend's own origin.
#   local Vite → deployed API : https://<your-app>.vercel.app/v1
#   local Vite → local backend: http://localhost:3000/v1
VITE_API_BASE_URL=https://<your-app>.vercel.app/v1

# Supabase project — used by @supabase/supabase-js for LOGIN ONLY (to obtain the
# ES256 access token the backend verifies). These are the public anon values,
# safe to ship in a browser bundle. Same project as the backend's SUPABASE_URL.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>
